---
layout: none
---
[
  {% assign all_docs = site.posts | concat: site.foundations | concat: site.tafsir | concat: site.refutations %}
  {% for doc in all_docs %}
  {
    "title"    : {{ doc.title | jsonify }},
    "url"      : {{ doc.url | relative_url | jsonify }},
    "category" : {{ doc.categories | join: ', ' | jsonify }},
    "tags"     : {{ doc.tags | join: ', ' | jsonify }},
    "excerpt"  : {{ doc.content | strip_html | normalize_whitespace | truncate: 120 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
